        if (lays(p2, n2 , p1[i].x, p1[i].y)==1) { p[t]=p1[i]; t++;}
    } 
    //проверили вершины первого многоугольника
    u=t;
    if (t==n1) S=1; //первый целиком лежит во втором
    else {
    for (i=0;i<n2;i++){
        if (lays(p1, n1 , p2[i].x, p2[i].y)==1) { 
            for (k=0;k<t;k++){
                if (p2[i].x!=p[k].x || p2[i].y!=p[k].y){
                    q++;
                }  else q=0;
            }
            if (q==t){
            p[t].x=p2[i].x;
            p[t].y=p2[i].y;
            t++;
            q=0;
            } 
        }
    }
}   //проверели вершины второго многоугольника 
    if (u==0 && t==n2) S=2;//второй многоугольник целиком лежит в первом
    else {
        for (i=0;i<n1;i++) {
            x1=p1[i].x;
            y1=p1[i].y;
            x2=p1[(i%n1+1)%n1].x;
            y2=p1[(i%n1+1)%n1].y;
        for(j=0;j<n2;j++){
            x3=p2[j].x;
            y3=p2[j].y;
            x4=p2[(j%n2+1)%n2].x;
            y4=p2[(j%n2+1)%n2].y;
            H=cross(x1,y1,x2,y2,x3,y3,x4,y4,&x,&y);
            //нашли пересечение
            if(H!=0){
                q=0;
                if (lays(p1, n1, x, y)==1 && lays(p2, n2, x, y)==1){
                    
                    for (k=0;k<t;k++){
                    if (x!=p[k].x || y!=p[k].y){

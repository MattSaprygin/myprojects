}
return t;
} 

void arranging (int n, Point *p){
Point temp;
int t;
int j, i, q;
for (j=0;j<n-1;j++) {
    for (i=1;i<n-j;i++){
        t=n-2;
        for (q=0;q<n;q++){
            if (q != j && q != j + i)
         t=t+l(p[j].x,p[j].y,p[j+i].x,p[j+i].y,p[q].x,p[q].y);
        }
        if (t==n-2 || t==(n-2)*2){
            temp.x=p[j+1].x;
            temp.y=p[j+1].y;
            p[j+1].x=p[j+i].x;
            p[j+1].y=p[j+i].y;
            p[j+i].x=temp.x;
            p[j+i].y=temp.y;
            break;
         }
    }
 }
}

float polygon_area(Point *p, int n) {
    if (n < 3) return 0;
    
    float area = 0;
    for (int i = 0; i < n; i++) {
        int j = (i + 1) % n;
        area += p[i].x * p[j].y - p[j].x * p[i].y;
    }
    return fabs(area) / 2.0f;
} 

float F(Point *p, int k, Point *points, int i, int n){// n/4- число прямоугольников, k-число вершин в пересечении p
    int j;
    int t;
    float S;
    Point rect[4];
    Point *temp = (Point*)malloc(100 * sizeof(Point));
    for (j=i+1;j<n/4;j++){
        rect[0]=points[4*j];
        rect[1]=points[4*j+1];
        rect[2]=points[4*j+2];
        rect[3]=points[4*j+3];
        t=intersection(p, k, rect, 4, temp);
        arranging(t,temp);
        S=polygon_area(temp,t);
        F(temp,t,points,j+1,n);
    }
    return S;
}



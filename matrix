#include <stdio.h>
#include <limits.h>  

int s(int n, int *M, int *visited, int row, int col, int current_sum) {
    int min_sum = INT_MAX;  
    int new_row, new_col;
    int move_r[4] = {-1, 0, 1, 0};
    int move_c[4] = {0, -1, 0, 1};
    int i, result;
    
    if (row == n-1 && col == n-1) {
        return current_sum; 
    }

    for (i = 0; i < 4; i++) {
        new_row = row + move_r[i];
        new_col = col + move_c[i];
        
        if (new_row >= 0 && new_row < n && 
            new_col >= 0 && new_col < n && 
            visited[new_row*n+new_col] == 0) {
            
            visited[new_row*n + new_col] = 1;
            result = s(n, M, visited, new_row, new_col, 
                      current_sum + M[new_row*n +new_col]);
            visited[new_row*n+new_col] = 0;  
            
            if (result < min_sum) {
                min_sum = result;
            }
        }
    }

    return min_sum;
}

int main(){
    int n;
    scanf("%d", &n); 
    int M[n][n];
    int visited[n][n];
    int i,j;
    for (i=0;i<n;i++){
        for (j=0;j<n;j++){
            printf("Введите %d_%d элемент", i+1, j+1);
            scanf("%d", &M[i][j]);
        }
    }
    for (i=0;i<n;i++){
        for (j=0;j<n;j++){
            visited[i][j]=0;
        }
    } 
    visited[0][0] = 1;
    
    int min_sum=s(n,(int*)M,(int*)visited,0,0,M[0][0]);
    printf("минимальный путь составляет %d", min_sum);
}

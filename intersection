typedef struct {
    float x, y;
} Point; 

int lays(Point *p, int n, float x0, float y0) {
    float x1, y1, x2, y2, x3, y3;
    int sign = 0;
    int i;
    const float eps = 1e-4;  // допуск
    
    for(i = 0; i < n; i++) {
        x1 = p[i].x;
        y1 = p[i].y;
        x2 = p[(i+1)%n].x;
        y2 = p[(i+1)%n].y;
        x3 = p[(i+2)%n].x;
        y3 = p[(i+2)%n].y;
        
        float r = x3*(y2-y1) + y3*(x1-x2) - x1*y2 + y1*x2;
        float l = x0*(y2-y1) + y0*(x1-x2) - x1*y2 + y1*x2;
        
        if (r * l >= -eps) {   // ← единственное изменение
            sign++;
        }
    }
    
    return (sign == n) ? 1 : 0;
}


float cross( float x1, float y1, float x2, float y2, float x3, float y3, float x4, float y4, float *x, float *y) {
        
        float A1, A2, B2, C2;
        float B1;
        float C1;
        A1=y2-y1;
        B1=x1-x2;
        C1=-x1*y2+y1*x2; 
        A2=y4-y3;
        B2=x3-x4;
        C2=-x3*y4+y3*x4;
        *y=(C1*A2-C2*A1)/(B2*A1-B1*A2);
        if (A1==0 && A2!=0){
             *y=-C1/B1;
             *x = (-B2*(*y) -C2)/A2;
        } else if ((A1==0 && A2==0)||(B1==0 && B2==0))
             return 0;
             else *x=(-C1-B1*(*y))/A1;
        return 1;
    }


